extends ../../layouts/default.pug
include ../../mixins/alert.pug
block main
    +alert-success(2000)
    +alert-error(2000)
    .my-5 
        .row.justify-content-center
            .col-5
                h1.text-center.mb-5 Xác nhận mã OTP
                form(
                    action="/user/password/otp"
                    method="POST"
                )
                    div(class="form-group")
                        label(for="email") Email
                        input(
                            type="email"
                            name="email"
                            id="email"
                            class="form-control"
                            placeholder="Email"
                            value=email
                            readonly
                        )
                    div(class="form-group")
                        label(for="otp") Mã OTP
                        input(
                            type="number"
                            name="otp"
                            id="otp"
                            class="form-control"
                            placeholder="Mã OTP"
                            required
                        )
                    button(type="submit" class="btn btn-primary w-100") Xác nhận OTP