extends ../../layouts/default.pug
include ../../mixins/alert.pug
block main
    +alert-success(2000)
    +alert-error(2000)
    .my-5 
        .row.justify-content-center
            .col-5
                h1.text-center.mb-5 Lấy lại mật khẩu
                form(
                    action="/user/password/forgot"
                    method="POST"
                )
                    div(class="form-group")
                        label(for="email") Email
                        input(
                            type="email"
                            name="email"
                            id="email"
                            class="form-control"
                            placeholder="Email"
                            required
                        )
                        button(type="submit" class="btn btn-primary w-100") Gửi mail xác nhận