mixin footer()
  footer.client-footer
    .client-footer__inner
      .client-footer__brand
        .client-footer__logo
          img(src="/images/dds_job_logo.svg" alt="DDS Jobs")
        div
          strong DDS Jobs
          p Nền tảng tìm việc làm hàng đầu Việt Nam. Kết nối nhà tuyển dụng với ứng viên tiềm năng.
          .client-footer__socials
            a(href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" aria-label="Facebook")
              i.fa-brands.fa-facebook-f
            a(href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn")
              i.fa-brands.fa-linkedin-in
            a(href="https://twitter.com/" target="_blank" rel="noopener noreferrer" aria-label="Twitter")
              i.fa-brands.fa-twitter
            a(href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram")
              i.fa-brands.fa-instagram

      .client-footer__links
        .client-footer__group
          h3 Khám phá
          a(href="/jobs") Việc làm
          a(href="/company") Công ty
          a(href="/saved-jobs") Việc làm đã lưu
        .client-footer__group
          h3 Tài khoản
          if(user)
            a(href="/user/info") Hồ sơ cá nhân
            a(href="/applications") Đã ứng tuyển
          else
            a(href="/user/login") Đăng nhập
            a(href="/user/register") Đăng ký
        .client-footer__group
          h3 Liên hệ
          span support@ddsjobs.vn
          span 024 1234 5678

    .client-footer__bottom
      span © 2026 DDS Jobs. All rights reserved.
      span Nền tảng tuyển dụng trực tuyến
