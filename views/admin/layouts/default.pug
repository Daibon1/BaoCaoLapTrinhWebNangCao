doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    title #{title || "Admin"}
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="/admin/css/style.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    //- link(rel="stylesheet", href="css/style.css")
    link(rel="stylesheet", href="/admin/css/dashboard.css")

  body
    if(role.permissions.length>0)
      // Header
      include ../partials/header.pug
      .admin-layout
        // Sidebar
        include ../partials/sidebar.pug 
        // Main
        main.main
          block main
      script(src="/admin/js/script.js")
      script(src="https://cdn.tiny.cloud/1/qzrvr6li0ogxfmetlhrz141aqk1vwsl8dvfo28lnqla5n259/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous")
      script(src="/admin/js/tinymce-config.js")
      script(src="https://cdn.jsdelivr.net/npm/chart.js")
      script(src="/admin/js/dashboard.js")
    else
      h2 Không có quyền truy cập