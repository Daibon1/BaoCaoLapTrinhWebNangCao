extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/pagination.pug

block styles
  link(rel="stylesheet", href="/admin/css/user-approval.css")

block main
  if(role.permissions.includes("user-approval-view"))
    +alert-success(3000)
    +alert-error(3000)

    .approval-page
      .approval-page__header
        .approval-page__title
          span.approval-page__icon
            i.fa-solid.fa-user-check
          div
            h1 Duyệt ứng tuyển
            p Quản lý hồ sơ ứng viên ứng tuyển vào các việc làm của bạn.

      .approval-summary
        .approval-summary__card
          .approval-summary__icon
            i.fa-solid.fa-file-signature
          .approval-summary__content
            span Tổng hồ sơ
            strong #{totalApplications}

        .approval-summary__card
          .approval-summary__icon
            i.fa-solid.fa-clock
          .approval-summary__content
            span Chờ xử lý
            strong #{pendingApplications}

        .approval-summary__card
          .approval-summary__icon
            i.fa-solid.fa-circle-check
          .approval-summary__content
            span Đã chấp nhận
            strong #{acceptedApplications}

      form.approval-filter(method="GET")
        .approval-filter__field
          i.fa-solid.fa-briefcase
          select.form-select(name="jobId")
            option(value="" selected=!selectedJobId) Tất cả công việc
            each job in jobs
              option(value=job.id selected=selectedJobId == job.id) #{job.title}
        .approval-filter__field
          i.fa-solid.fa-circle-check
          select.form-select(name="status")
            option(value="" selected=!selectedStatus) Tất cả trạng thái
            option(value="pending" selected=selectedStatus == "pending") Pending
            option(value="reviewing" selected=selectedStatus == "reviewing") Reviewing
            option(value="interview" selected=selectedStatus == "interview") Interview
            option(value="accepted" selected=selectedStatus == "accepted") Accepted
            option(value="rejected" selected=selectedStatus == "rejected") Rejected
        .approval-filter__field.approval-filter__field--search
          i.fa-solid.fa-magnifying-glass
          input.form-control(
            type="text"
            name="keyword"
            placeholder="Tìm theo tên/email ứng viên..."
            value=keyword
          )
        button.btn.btn-primary(type="submit")
          i.fa-solid.fa-filter
          span Lọc
        a.btn.btn-outline-secondary(href=`/${prefixAdmin}/user-approval`)
          i.fa-solid.fa-rotate-left
          span Xóa lọc

      .approval-shell
        .approval-shell__top
          h2 Danh sách ứng viên
          .approval-shell__meta
            i.fa-solid.fa-address-book
            if countApplications > 0
              span Hiển thị #{pagination.skipItem + 1}-#{pagination.skipItem + applications.length} / #{countApplications} hồ sơ
            else
              span 0 hồ sơ

        .table-responsive
          table.approval-table.table.align-middle.mb-0
            thead
              tr
                th Ứng viên
                th Việc làm
                th Hồ sơ
                th Trạng thái
                th Ngày apply
                th.text-end Hành động
            tbody
              if applications.length > 0
                each app in applications
                  tr
                    td
                      .approval-candidate
                        .approval-avatar
                          if app.userId && app.userId.avatar
                            img(src=app.userId.avatar alt=app.userId.fullName)
                          else
                            img(src="/admin/images/no-image.png" alt="No Image")
                        .approval-candidate__info
                          strong #{app.userId ? app.userId.fullName : "Chưa cập nhật"}
                          span #{app.userId ? app.userId.email : "Chưa cập nhật"}

                    td
                      if app.jobId
                        a.approval-job(href=`/admin/job/detail/${app.jobId._id}`) #{app.jobId.title}
                      else
                        span.approval-muted Chưa cập nhật

                    td
                      .approval-profile-links
                        if app.cvUrl
                          a.approval-cv(href=app.cvUrl target="_blank" rel="noopener noreferrer")
                            i.fa-solid.fa-file-lines
                            span CV
                        else
                          span.approval-muted Không có CV
                        if app.coverLetter
                          span.cover-preview.approval-cover(data-text=app.coverLetter)
                            i.fa-solid.fa-envelope-open-text
                            span Thư

                    td
                      span(class=`approval-status approval-status--${app.status}`)
                        = app.status

                    td
                      span.approval-date #{app.createdAt.toLocaleDateString()}

                    td
                      .approval-actions
                        form(method="POST", action=`/admin/user-approval/change-status/${app._id}?_method=PATCH` class="form-status-application")
                          select.form-select.form-select-sm(name="status")
                            option(value="pending" selected=app.status=="pending") Pending
                            option(value="reviewing" selected=app.status=="reviewing") Reviewing
                            option(value="interview" selected=app.status=="interview") Interview
                            option(value="accepted" selected=app.status=="accepted") Accepted
                            option(value="rejected" selected=app.status=="rejected") Rejected
                          button.btn.btn-success.btn-sm(type="submit")
                            i.fa-solid.fa-check
                            span Cập nhật
              else
                tr
                  td(colspan="6")
                    .approval-empty
                      i.fa-solid.fa-user-slash
                      h3 Chưa có hồ sơ ứng tuyển nào

        .approval-pagination
          +pagination(pagination)

    .div-cover-modal
      .div-cover-modal__overlay
      .div-cover-modal__content
        span.div-cover-modal__close x
        h3 Cover Letter
        p.div-cover-modal__text

    script(src="/admin/js/user-approval.js")
  else
    h2 Không có quyền truy cập
