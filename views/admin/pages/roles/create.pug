extends ../../layouts/default.pug 
include ../../mixins/alert.pug
block main
  if(role.permissions.includes("roles-create"))
    +alert-success(2000)
    +alert-error(2000)
    h2(class="mb-4") Thêm nhóm quyền
    form(action=`/${prefixAdmin}/roles/create` method="post")
      .form-group
        label(for="title") Tên nhóm quyền
        input.form-control(type="text" name="title" id="title" required)
      .form-group
        label(for="description") Mô tả nhóm quyền
        input.form-control(type="text" name="description" id="description")
      .form-group.mt-3
        button.btn.btn-primary(type="submit") Thêm
  else 
    h2 Không có quyền truy cập