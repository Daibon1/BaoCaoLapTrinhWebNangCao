extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/select-tree.pug

block styles
  link(rel="stylesheet", href="/admin/css/job.css")

block main
  if(role.permissions.includes("jobs-create"))
    +alert-success(3000)
    +alert-error(3000)

    .job-create-page
      .job-page__header
        .job-page__title
          span.job-page__icon
            i.fa-solid.fa-briefcase
          div
            h1 Tạo việc làm
            p.job-create-page__subtitle Điền thông tin tuyển dụng để đăng việc làm mới
        a.btn.btn-outline-secondary.job-create-page__back(href=`/${prefixAdmin}/job`)
          i.fa-solid.fa-arrow-left
          span Quay lại

      form.job-create-form(action=`/${prefixAdmin}/job/create` method="POST" id="form-create-job" enctype="multipart/form-data")
        .job-create-form__main
          section.job-create-panel
            .job-create-panel__head
              span.job-create-panel__icon
                i.fa-solid.fa-file-lines
              div
                h2 Thông tin chính
                p Nội dung hiển thị với ứng viên

            .job-form-grid
              .job-form-field.job-form-field--wide
                label.form-label(for="job-title") Tiêu đề công việc
                input.form-control#job-title(
                  type="text"
                  name="title"
                  placeholder="VD: Backend Developer NodeJS"
                  required
                )

              .job-form-field
                label.form-label(for="job-category") Danh mục việc làm
                select.form-select#job-category(name="category")
                  option(value="") Chọn danh mục
                  +select-tree(categories)

              .job-form-field
                label.form-label Chế độ nổi bật
                .job-choice-group
                  label.job-choice(for="featured-1")
                    input.form-check-input(
                      type="radio"
                      name="featured"
                      id="featured-1"
                      value="1"
                    )
                    span Nổi bật
                  label.job-choice(for="featured-0")
                    input.form-check-input(
                      type="radio"
                      name="featured"
                      id="featured-0"
                      value="0"
                      checked
                    )
                    span Không nổi bật

              .job-form-field.job-form-field--wide
                label.form-label(for="job-description") Mô tả công việc
                textarea.form-control.tinymce#job-description(
                  name="description"
                  rows="8"
                )

          section.job-create-panel
            .job-create-panel__head
              span.job-create-panel__icon
                i.fa-solid.fa-sliders
              div
                h2 Yêu cầu và đãi ngộ
                p Kỹ năng, địa điểm, lương và kinh nghiệm

            .job-form-grid
              .job-form-field.job-form-field--wide
                label.form-label(for="skillInput") Kỹ năng
                input.form-control#skillInput(
                  type="text"
                  name="skill"
                  placeholder="VD: NodeJS, MongoDB, React"
                )
                small.job-form-hint Tối đa 5 kỹ năng, cách nhau bằng dấu phẩy
                .invalid-feedback#skillError

              .job-form-field
                label.form-label(for="job-location") Địa điểm làm việc
                select.form-select#job-location(name="location")
                  option(value="") Chọn địa điểm
                  option(value="Hà Nội") Hà Nội
                  option(value="TP.HCM") TP.HCM
                  option(value="Đà Nẵng") Đà Nẵng

              .job-form-field
                label.form-label(for="job-experience") Kinh nghiệm yêu cầu
                input.form-control#job-experience(
                  type="text"
                  name="experience"
                  placeholder="VD: 2 năm"
                )

              .job-form-field
                label.form-label Thời gian làm việc
                .job-choice-group
                  label.job-choice
                    input.form-check-input(type="radio" name="type" value="Full-time" checked)
                    span Full-time
                  label.job-choice
                    input.form-check-input(type="radio" name="type" value="Part-time")
                    span Part-time

              .job-form-field
                label.form-label(for="job-salary-min") Lương tối thiểu (VNĐ)
                input.form-control#job-salary-min(type="number" name="salaryMin" min="0" placeholder="10000000")

              .job-form-field
                label.form-label(for="job-salary-max") Lương tối đa (VNĐ)
                input.form-control#job-salary-max(type="number" name="salaryMax" min="0" placeholder="20000000")

              .job-form-field
                label.form-label(for="job-position") Vị trí
                input.form-control#job-position(type="number" name="position" min="0" placeholder="Tự động tăng")

        aside.job-create-form__side
          section.job-create-panel.job-create-panel--sticky
            .job-create-panel__head
              span.job-create-panel__icon
                i.fa-solid.fa-image
              div
                h2 Hình ảnh và trạng thái
                p Thiết lập trước khi đăng

            .job-form-field
              label.form-label Thumbnail
              .job-upload#preview-img
                img(src="", alt="" id="img-preview")
                .job-upload__content
                  i.fa-solid.fa-cloud-arrow-up
                  span Chọn ảnh công việc
                  small PNG, JPG hoặc WEBP
                input.job-upload__input(
                  type="file"
                  name="thumbnail"
                  accept="image/*"
                  id="file-input"
                )

            .job-form-field
              label.form-label Trạng thái
              .job-pending-note
                i.fa-solid.fa-clock
                div
                  strong Chờ admin duyệt
                  span Việc làm mới sẽ được lưu ở trạng thái chờ duyệt trước khi hiển thị.

            .job-create-actions
              button.btn.btn-primary(type="submit")
                i.fa-solid.fa-plus
                span Tạo mới
              a.btn.btn-outline-secondary(href=`/${prefixAdmin}/job`)
                i.fa-solid.fa-xmark
                span Hủy

    script(src="/admin/js/job.js")
  else
    h2 Không có quyền truy cập
