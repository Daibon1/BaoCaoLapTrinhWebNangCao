extends ../../layouts/default.pug
include ../../mixins/alert.pug

block styles
  link(rel="stylesheet", href="/admin/css/job.css")

block main
  if(role.permissions.includes("jobs-view"))
    +alert-success(3000)
    +alert-error(3000)

    .job-detail-page
      .job-page__header
        .job-page__title
          span.job-page__icon
            i.fa-solid.fa-briefcase
          div
            h1 Chi tiết việc làm
            p.job-detail-page__subtitle Xem thông tin tuyển dụng đã đăng
        .job-detail-page__actions
          if(role.permissions.includes("jobs-edit"))
            a.btn.btn-primary.job-detail-page__button(href=`/${prefixAdmin}/job/edit/${job.id}`)
              i.fa-solid.fa-pen
              span Chỉnh sửa
          a.btn.btn-outline-secondary.job-detail-page__button(href=`/${prefixAdmin}/job`)
            i.fa-solid.fa-arrow-left
            span Quay lại

      .job-detail-layout
        .job-detail-main
          section.job-detail-panel
            .job-detail-panel__head
              span.job-detail-panel__icon
                i.fa-solid.fa-file-lines
              div
                h2 Thông tin chính
                p Nội dung tổng quan của việc làm

            .job-detail-title
              span.job-detail-title__label Tiêu đề công việc
              h3 #{job.title || "Chưa cập nhật"}

            .job-detail-grid
              .job-detail-item
                span.job-detail-item__label Danh mục
                strong #{category && category.title ? category.title : "Chưa cập nhật"}
              .job-detail-item
                span.job-detail-item__label Địa điểm
                strong #{job.location || "Chưa cập nhật"}
              .job-detail-item
                span.job-detail-item__label Thời gian làm việc
                strong #{job.type || "Chưa cập nhật"}
              .job-detail-item
                span.job-detail-item__label Kinh nghiệm
                strong #{job.experience || "Chưa cập nhật"}
              .job-detail-item
                span.job-detail-item__label Mức lương
                strong
                  if job.salaryMin && job.salaryMax
                    | #{job.salaryMin.toLocaleString()} - #{job.salaryMax.toLocaleString()} VNĐ
                  else if job.salaryMin
                    | Tối thiểu #{job.salaryMin.toLocaleString()} VNĐ
                  else if job.salaryMax
                    | Tối đa #{job.salaryMax.toLocaleString()} VNĐ
                  else
                    | Chưa cập nhật
              .job-detail-item
                span.job-detail-item__label Vị trí
                strong #{job.position || "Tự động"}

          section.job-detail-panel
            .job-detail-panel__head
              span.job-detail-panel__icon
                i.fa-solid.fa-list-check
              div
                h2 Kỹ năng
                p Các kỹ năng yêu cầu cho vị trí này

            if job.skill && job.skill.length > 0
              .job-detail-skills
                each skill in job.skill
                  span.job-detail-skill #{skill}
            else
              .job-detail-empty Chưa cập nhật kỹ năng

          section.job-detail-panel
            .job-detail-panel__head
              span.job-detail-panel__icon
                i.fa-solid.fa-align-left
              div
                h2 Mô tả công việc
                p Chi tiết nội dung tuyển dụng

            if job.description
              .job-detail-description !{job.description}
            else
              .job-detail-empty Chưa cập nhật mô tả công việc

        aside.job-detail-side
          section.job-detail-panel.job-detail-panel--sticky
            .job-detail-cover
              if job.thumbnail
                img(src=job.thumbnail alt=job.title)
              else
                img(src="/admin/images/no-image.png" alt="No Image")

            .job-detail-side__body
              if job.status == "active"
                span.job-status.job-status--active
                  i.fa-solid.fa-circle-check
                  span Hoạt động
              else if job.status == "pending"
                span.job-status.job-status--pending
                  i.fa-solid.fa-clock
                  span Chờ duyệt
              else if job.status == "inactive"
                span.job-status.job-status--inactive
                  i.fa-solid.fa-circle-pause
                  span Ngừng hoạt động
              else
                span.job-status.job-status--inactive
                  i.fa-solid.fa-circle-question
                  span #{job.status || "Chưa cập nhật"}

              .job-detail-side__summary
                .job-detail-side__row
                  span Nổi bật
                  strong #{job.featured == "1" ? "Có" : "Không"}
                .job-detail-side__row
                  span Danh mục
                  strong #{category && category.title ? category.title : "Chưa cập nhật"}
                .job-detail-side__row
                  span Địa điểm
                  strong #{job.location || "Chưa cập nhật"}

              .job-detail-side__actions
                if(role.permissions.includes("jobs-edit"))
                  a.btn.btn-primary(href=`/${prefixAdmin}/job/edit/${job.id}`)
                    i.fa-solid.fa-pen
                    span Chỉnh sửa
                a.btn.btn-outline-secondary(href=`/${prefixAdmin}/job`)
                  i.fa-solid.fa-arrow-left
                  span Danh sách

    script(src="/admin/js/job.js")
  else
    h2 Không có quyền truy cập
