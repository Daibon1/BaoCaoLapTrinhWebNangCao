header.header.fixed-top
  .header-inner
    // ===== Logo =====
    a.header-logo(href=`/${prefixAdmin}/dashboard`)
      i.fa-solid.fa-briefcase
      span DDSJob

    // ===== Right Actions =====
    .header-actions
      if(role.title === "Employer")
        if(user.company_id)
          a.header-btn.header-btn--company(
            href=`/${prefixAdmin}/company/my-company`
            title="Công ty của tôi"
          )
            i.fa-regular.fa-building
            span #{user.company_id.name}
        else
          a.header-btn.header-btn--company(
            href=`/${prefixAdmin}/company/create`
            title="Tạo công ty"
          )
            i.fa-regular.fa-building
            span Tạo công ty

      a.header-btn.header-btn--account(
        href=`/${prefixAdmin}/my-account`
        title="Tài khoản"
      )
        if(user.avatar)
          img.header-avatar(src=user.avatar alt=user.fullName)
        else
          .header-avatar.header-avatar--fallback
            i.fa-solid.fa-user
        span.header-name #{user.fullName || "Admin"}

      a.header-btn.header-btn--logout(
        href=`/${prefixAdmin}/auth/logout`
        title="Đăng xuất"
      )
        i.fa-solid.fa-right-from-bracket